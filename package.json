{
  "name": "take-my-money",
  "version": "0.0.0",
  "description": "Take My Money monorepo with pnpm",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs --fix && prettier --write .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.58.1"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "prettier": "^3.8.2"
  }
}
