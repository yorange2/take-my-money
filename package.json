{
  "name": "last-key",
  "version": "0.0.0",
  "description": "LastKey monorepo with pnpm",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs --fix && prettier --write .",
    "format": "prettier --write .",
    "setup:service": "bash scripts/dev.sh start",
    "services:start": "podman-compose --env-file .env.local -f podman-compose.yml up -d",
    "services:stop": "podman-compose --env-file .env.local -f podman-compose.yml down",
    "services:restart": "podman-compose --env-file .env.local -f podman-compose.yml restart",
    "services:logs": "podman-compose --env-file .env.local -f podman-compose.yml logs -f",
    "services:ps": "podman-compose --env-file .env.local -f podman-compose.yml ps",
    "db:shell": "bash scripts/dev.sh db-shell",
    "redis:cli": "bash scripts/dev.sh redis-cli"
  },
  "dependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.58.1"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "prettier": "^3.8.2"
  }
}
